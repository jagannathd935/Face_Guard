# FaceGuard 2.0 Environment Variables
# Use this as a template for your local .env file or Render/Supabase environment settings.

# Secret key for session signing (CHANGE THIS in production!)
FACEGUARD_SECRET_KEY=dev-change-me-in-production-very-long-string

# Database URL for Supabase (e.g., postgresql://postgres.xxxx:password@xxxx.supabase.co:5432/postgres)
# If not provided, it defaults to a local SQLite database in the instance/ folder.
# DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# Session Settings
FACEGUARD_SESSION_TTL=10
FACEGUARD_FACE_TOLERANCE=0.55
FACEGUARD_LBPH_MAX_DIST=85

# Development Settings
FLASK_DEBUG=true

# Optional: Set to 1 to enable face_recognition library during registration (requires dlib)
FACEGUARD_FR_ON_REGISTER=0
